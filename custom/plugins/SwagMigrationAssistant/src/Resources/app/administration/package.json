{
  "name": "swag-migration-assistant",
  "description": "Plugin for migrating data to Shopware 6",
  "author": "shopware AG",
  "license": "MIT",
  "scripts": {
    "lint": "npx eslint .",
    "lint:types": "tsc --noEmit",
    "lint:fix": "npm run lint -- --fix",
    "lint:scss": "npx stylelint ./**/*.scss",
    "lint:scss:fix": "npm run lint:scss -- --fix",
    "format": "npx prettier --check \"src/**/*.{js,ts}\" --config ../../../../.prettierrc.json --cache",
    "format:fix": "npx prettier --write \"src/**/*.{js,ts}\" --config ../../../../.prettierrc.json --cache",
    "format:md": "npx prettier --check \"../../../../*.md\" --config ../../../../.prettierrc.json --cache",
    "format:md:fix": "npx prettier --write \"../../../../*.md\" --config ../../../../.prettierrc.json --cache",
    "format:yml": "npx prettier --check \"../../../../.github/**/*.{yml,yaml}\" --config ../../../../.prettierrc.json --cache",
    "format:yml:fix": "npx prettier --write \"../../../../.github/**/*.{yml,yaml}\" --config ../../../../.prettierrc.json --cache"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@shopware-ag/meteor-admin-sdk": "6.4.0",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "axios": "0.30.3",
    "eslint": "9.39.3",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-file-progress": "1.5.0",
    "eslint-plugin-filename-rules": "1.3.1",
    "eslint-plugin-html": "7.1.0",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-inclusive-language": "2.2.1",
    "eslint-plugin-vue": "9.32.0",
    "eslint-plugin-vuejs-accessibility": "2.4.1",
    "globals": "15.15.0",
    "prettier": "3.6.2",
    "prettier-plugin-multiline-arrays": "3.0.6",
    "stylelint": "14.16.1",
    "stylelint-config-standard": "26.0.0",
    "stylelint-config-standard-scss": "5.0.0",
    "stylelint-junit-formatter": "0.2.2",
    "typescript": "5.7.3",
    "vue": "3.5.22",
    "vue-eslint-parser": "9.4.3"
  },
  "overrides": {
    "picomatch": "4.0.4"
  }
}
